generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Company {
  id                   String   @id @default(cuid())
  name                 String   @unique
  employeeSatisfaction Int      // 1–5
  customerSatisfaction Int      // 1–5
  workLifeBalance      Int      // 1–5
  politicalAlignment   Int      // 1–5
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  jobs                 Job[]
}

model Job {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  title       String
  url         String
  location    String   @default("")
  workMode    String   @default("remote") // in-person, hybrid, remote
  postedAt    DateTime
  salaryRange String
  benefits    Int      // 1–5
  status      String   @default("new") // new, applied, screened, interviewed, tested, offer, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([status])
}

model ScrapingRun {
  id          String    @id @default(cuid())
  source      String    // e.g. "adzuna", "greenhouse", "linkedin"
  status      String    @default("pending") // pending, running, completed, failed
  jobsFound   Int       @default(0)
  jobsNew     Int       @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
}
