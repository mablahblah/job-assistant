generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Company {
  id                   String   @id @default(cuid())
  name                 String   @unique
  employeeSatisfaction Int?     // 1–5
  customerSatisfaction Int?     // 1–5
  workLifeBalance      Int?     // 1–5
  politicalAlignment   Int?     // 1–5
  benefits             Int?     // 1–5
  note                 String?  // brief scoring rationale from Claude
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  jobs                 Job[]
}

model Job {
  id          String      @id @default(cuid())
  companyId   String
  company     Company     @relation(fields: [companyId], references: [id])
  title       String
  url         String
  location    String      @default("")
  workMode    String      @default("remote") // in-person, hybrid, remote
  postedAt    DateTime
  salaryRange String
  status          String      @default("backlog") // backlog, too far, won't apply, app. sent, rejected, screening, interview, test, offer
  locationFlagged Boolean     @default(false) // true when auto-set to "too far" because remote location didn't match inclusion/exclusion lists
  modifiedAt      DateTime?   // tracks when status was last changed (null = never changed)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  sources     JobSource[]

  @@unique([url])
  @@index([companyId])
  @@index([status])
}

model SearchTerm {
  id        String      @id @default(cuid())
  query     String      @unique
  createdAt DateTime    @default(now())
  sources   JobSource[]
}

model JobSource {
  id           String     @id @default(cuid())
  jobId        String
  job          Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  searchTermId String
  searchTerm   SearchTerm @relation(fields: [searchTermId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@unique([jobId, searchTermId])
  @@index([jobId])
  @@index([searchTermId])
}

// URLs of deleted jobs — scraper skips these so they don't reappear
model BlockedJob {
  id        String   @id @default(cuid())
  url       String   @unique
  createdAt DateTime @default(now())
}

model ScrapingRun {
  id          String    @id @default(cuid())
  source      String    // e.g. "adzuna", "greenhouse", "linkedin"
  status      String    @default("pending") // pending, running, completed, failed
  jobsFound   Int       @default(0)
  jobsNew     Int       @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?
}
